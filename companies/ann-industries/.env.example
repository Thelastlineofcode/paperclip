# Ann Engine — PopeBot runtime config
# Copy to .env and fill in values. Never commit .env.

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true

# ── Remote access ─────────────────────────────────────────────────────────────
# Public URL for webhooks, Telegram, and Traefik hostname
# Set to your Cloudflare tunnel URL or Fly.io URL for remote access
APP_URL=http://localhost:3200
APP_HOSTNAME=localhost

# ── GitHub ────────────────────────────────────────────────────────────────────
GH_TOKEN=
GH_OWNER=Thelastlineofcode
GH_REPO=paperclip
GH_WEBHOOK_SECRET=

# ── LLM ──────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ── rickd integration ─────────────────────────────────────────────────────────
RICKD_API_KEY=z4Kez6EcOhilhkykEGl1xhYcDCAUtOxEtR8iHh3lOc
RICKD_URL=http://host.docker.internal:9000

# ── Optional ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
